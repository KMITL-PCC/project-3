generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Activity {
  id          String   @id
  title       String
  description String?
  imageUrl    String?
  startTime   DateTime
  endTime     DateTime
  adId        String?
  qrCodeId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Ad          Ad?      @relation(fields: [adId], references: [id])
  QrCode      QrCode?  @relation(fields: [qrCodeId], references: [id])
  Device      Device[] @relation("ActivityToDevice")
}

model Ad {
  id        String     @id
  name      String
  url       String
  type      String     @default("IMAGE")
  createdAt DateTime   @default(now())
  Activity  Activity[]
  Device    Device[]
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String
  username  String
  action    String
  targetId  String
  details   Json?
  createdAt DateTime @default(now())
}

model Device {
  id            String          @id
  macAddress    String          @unique
  deviceName    String?
  roomCode      String?         @unique
  ipAddress     String?
  status        String          @default("PENDING")
  lastSeen      DateTime        @default(now())
  zoneId        String?
  adId          String?
  lastCommand   String?
  Ad            Ad?             @relation(fields: [adId], references: [id])
  room          room?           @relation(fields: [roomCode], references: [room_code])
  Zone          Zone?           @relation(fields: [zoneId], references: [id])
  class_session class_session[]
  Activity      Activity[]      @relation("ActivityToDevice")
}

model QrCode {
  id          String     @id
  name        String
  description String?
  type        String     @default("GENERATED")
  data        String
  createdAt   DateTime   @default(now())
  Activity    Activity[]
}

model Zone {
  id     String   @id
  name   String   @unique
  Device Device[]
}

model building {
  building_code String @id @db.VarChar(20)
  building_name String @db.VarChar(200)
  room          room[]
}

model checkin {
  id         Int       @id @default(autoincrement())
  student_id String    @db.VarChar(8)
  room_code  String    @db.VarChar(10)
  check_in   DateTime?
  check_out  DateTime?
  room       room      @relation(fields: [room_code], references: [room_code])
  users      users     @relation(fields: [student_id], references: [StudentId])

  @@index([check_in])
  @@index([room_code])
  @@index([student_id])
}

model class_session {
  id           Int      @id @default(autoincrement())
  subject_id   Int
  room_id      String   @db.VarChar(10)
  device_id    String
  qr_token     String   @unique @db.VarChar(255)
  start_time   DateTime
  end_time     DateTime
  max_students Int
  Device       Device   @relation(fields: [device_id], references: [id])
  room         room     @relation(fields: [room_id], references: [room_code])
}

model room {
  room_code     String          @id @db.VarChar(10)
  building_code String?         @db.VarChar(20)
  room_floor    String?         @db.VarChar(10)
  room_capacity String?         @db.VarChar(13)
  room_desc     String?         @db.VarChar(47)
  Device        Device?
  checkin       checkin[]
  class_session class_session[]
  building      building?       @relation(fields: [building_code], references: [building_code])
}

model users {
  id        Int       @id @default(autoincrement())
  StudentId String?   @unique @db.VarChar(8)
  prefix    String?   @db.VarChar(20)
  fname     String?   @db.VarChar(50)
  lname     String?   @db.VarChar(50)
  nickname  String?   @db.VarChar(50)
  password  String    @default("1234") @db.VarChar(255)
  roleId    String?   @db.VarChar(20)
  img       String?
  createdAt DateTime  @default(now())
  majorId   String?   @db.VarChar(20)
  phone     String?   @db.VarChar(15)
  email     String?   @db.VarChar(100)
  gen       String?   @db.VarChar(10)
  checkin   checkin[]
  major     major?    @relation(fields: [majorId], references: [majorId])
  Role      Role?     @relation(fields: [roleId], references: [roleId])
}

model Role {
  id     Int     @id @default(autoincrement())
  name   String  @unique @db.VarChar(50)
  roleId String  @unique @db.VarChar(20)
  users  users[]
}

model major {
  id      Int     @id @default(autoincrement())
  majorId String  @unique @db.VarChar(20)
  name    String  @db.VarChar(100)
  users   users[]
}
