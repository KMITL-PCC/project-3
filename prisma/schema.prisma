generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Activity {
  id          String   @id
  title       String
  description String?
  imageUrl    String?
  startTime   DateTime
  endTime     DateTime
  adId        String?
  qrCodeId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Ad          Ad?      @relation(fields: [adId], references: [id])
  QrCode      QrCode?  @relation(fields: [qrCodeId], references: [id])
  Device      Device[] @relation("ActivityToDevice")
}

model Ad {
  id        String     @id
  name      String
  url       String
  type      String     @default("IMAGE")
  createdAt DateTime   @default(now())
  Activity  Activity[]
  Device    Device[]
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String
  username  String
  action    String
  targetId  String
  details   Json?
  createdAt DateTime @default(now())
}

model Device {
  id            String          @id
  macAddress    String          @unique
  deviceName    String?
  roomCode      String?         @unique
  ipAddress     String?
  status        String          @default("PENDING")
  lastSeen      DateTime        @default(now())
  zoneId        String?
  adId          String?
  lastCommand   String?
  Ad            Ad?             @relation(fields: [adId], references: [id])
  room          room?           @relation(fields: [roomCode], references: [room_code])
  Zone          Zone?           @relation(fields: [zoneId], references: [id])
  class_session class_session[]
  Activity      Activity[]      @relation("ActivityToDevice")
}

model QrCode {
  id          String     @id
  name        String
  description String?
  type        String     @default("GENERATED")
  data        String
  createdAt   DateTime   @default(now())
  Activity    Activity[]
}

model Zone {
  id     String   @id
  name   String   @unique
  Device Device[]
}

model class_session {
  id           Int      @id @default(autoincrement())
  subject_id   Int
  room_id      String   @db.VarChar(10)
  device_id    String
  qr_token     String   @unique @db.VarChar(255)
  start_time   DateTime
  end_time     DateTime
  max_students Int
  device_iot   Device   @relation(fields: [device_id], references: [id])
  room         room     @relation(fields: [room_id], references: [room_code])
}

model room {
  room_code     String          @id @db.VarChar(10)
  building_code String?         @db.VarChar(20)
  room_floor    String?         @db.VarChar(10)
  room_capacity String?         @db.VarChar(13)
  room_desc     String?         @db.VarChar(47)
  Device        Device?
  checkin       checkin[]
  class_session class_session[]
  building      building?       @relation(fields: [building_code], references: [building_code])
}

model building {
  building_code String @id @db.VarChar(20)
  building_name String @db.VarChar(200)
  room          room[]
}

model checkin {
  id          Int       @id @default(autoincrement())
  national_id String    @db.VarChar(13)
  room_code   String    @db.VarChar(10)
  check_in    DateTime?
  check_out   DateTime?
  student     student   @relation(fields: [national_id], references: [national_id])
  room        room      @relation(fields: [room_code], references: [room_code])

  @@index([check_in])
  @@index([national_id])
  @@index([room_code])
}

model student {
  national_id String    @id @db.VarChar(13)
  prefix      String?   @db.VarChar(20)
  fname       String?   @db.VarChar(50)
  lname       String?   @db.VarChar(50)
  user_id     String?   @db.VarChar(30)
  major       String?   @db.VarChar(100)
  checkin     checkin[]
}

model users {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  role      String   @db.VarChar(20)
  img       String?
  createdAt DateTime @default(now())
}
